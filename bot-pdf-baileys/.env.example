# Porta HTTP do bot (padrão: 3210)
PORT=3210

# Pasta raiz onde ficam os PDFs por grupo
# Estrutura esperada: PDF_BASE_DIR/grupo-1/*.pdf, PDF_BASE_DIR/grupo-2/*.pdf, ...
PDF_BASE_DIR=C:/caminho/para/seus/pdfs

# Chave de autenticação para proteger os endpoints do bot
# Deve ser a mesma que PDF_BAILEYS_BOT_API_KEY no backend/.env
BOT_API_KEY=cole_aqui_o_mesmo_valor_do_backend

# Caminho para o arquivo de configuração de grupos (padrão: groups.json na pasta do bot)
# GROUPS_CONFIG=./groups.json

# URL do backend para envio de mensagens recebidas ao sistema de auto-resposta
# Mude apenas se o backend não estiver em localhost:8000
BACKEND_URL=http://localhost:8000
